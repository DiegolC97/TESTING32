{
  "extends": ["next/core-web-vitals", "prettier"],
  "overrides": [
    {
      "files": ["src/domain/**/*"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@application/*", "@infrastructure/*", "@interfaces/*"],
                "message": "domain/ must not import from other layers. See CLAUDE.md."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/application/**/*"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@infrastructure/*", "@interfaces/*"],
                "message": "application/ may only import from domain/. See CLAUDE.md."
              }
            ]
          }
        ]
      }
    }
  ]
}
